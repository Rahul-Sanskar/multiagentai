APP_NAME=MultiAgentAI
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

# Database — SQLite for dev/Render free tier
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# CORS — comma-separated allowed origins
# Dev: * allows all. Production: set to your Netlify URL
ALLOWED_ORIGINS_STR=*

# LLM — Groq (free) → Ollama (local) → template fallback
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Security
SECRET_KEY=change-me-in-production

# X (Twitter) API
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Instagram / Meta Graph API
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# Impact tracker delay (seconds)
IMPACT_FETCH_DELAY_SECONDS=3600
